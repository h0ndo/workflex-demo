{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@cucumber/cucumber"]
  },
  "include": ["features/**/*.ts", "steps/**/*.ts", "support/**/*.ts"]
}
