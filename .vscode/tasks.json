{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OpenClaw: TUI",
      "type": "shell",
      "command": "openclaw tui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Workflex: Postgres Up (Docker Compose)",
      "type": "shell",
      "command": "docker compose up -d postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Workflex: Postgres Down (Docker Compose)",
      "type": "shell",
      "command": "docker compose stop postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Workflex: Postgres Logs (Docker Compose)",
      "type": "shell",
      "command": "docker compose logs -f postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Workflex: Backend (Spring Boot)",
      "type": "shell",
      "command": ".\\mvnw spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Workflex: Frontend (Angular)",
      "type": "shell",
      "command": "npm run start -- --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Workflex: Start Backend + Frontend",
      "dependsOn": [
        "Workflex: Backend (Spring Boot)",
        "Workflex: Frontend (Angular)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Workflex: Start Postgres + Backend + Frontend",
      "dependsOn": [
        "Workflex: Postgres Up (Docker Compose)",
        "Workflex: Backend (Spring Boot)",
        "Workflex: Frontend (Angular)"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
