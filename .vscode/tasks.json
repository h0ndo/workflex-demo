{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TUI",
      "type": "shell",
      "command": "openclaw tui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "PG Up",
      "type": "shell",
      "command": "docker compose up -d postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "PG Down",
      "type": "shell",
      "command": "docker compose stop postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "PG Logs",
      "type": "shell",
      "command": "docker compose logs -f postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": ".\\mvnw spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run start -- --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Start App",
      "dependsOn": [
        "Backend",
        "Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Start All",
      "dependsOn": [
        "PG Up",
        "Backend",
        "Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
