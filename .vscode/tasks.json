{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TUI",
      "type": "shell",
      "command": "openclaw tui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": false
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "PG Up",
      "type": "shell",
      "command": "docker compose up -d postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "PG Down",
      "type": "shell",
      "command": "docker compose stop postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "PG Logs",
      "type": "shell",
      "command": "docker compose logs -f postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend",
      "type": "shell",
      "command": "export JAVA_HOME=\"$(dirname \"$(dirname \"$(readlink -f \"$(command -v java)\")\")\")\"; if ./mvnw -v | grep -Eq 'Java version: (17|18|19|2[0-9])'; then ./mvnw spring-boot:run; else echo 'ERROR: Maven is not using Java 17+ (recommended: 21).'; ./mvnw -v; exit 1; fi",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "npm run start -- --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-run"
      },
      "problemMatcher": []
    },
    {
      "label": "FE Unit",
      "type": "shell",
      "command": "npm test -- --watch=false",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-test"
      },
      "problemMatcher": []
    },
    {
      "label": "BE Unit",
      "type": "shell",
      "command": "export JAVA_HOME=\"$(dirname \"$(dirname \"$(readlink -f \"$(command -v java)\")\")\")\"; if ./mvnw -v | grep -Eq 'Java version: (17|18|19|2[0-9])'; then ./mvnw test; else echo 'ERROR: Maven is not using Java 17+ (recommended: 21).'; ./mvnw -v; exit 1; fi",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-test"
      },
      "problemMatcher": []
    },
    {
      "label": "E2E",
      "type": "shell",
      "command": "npm test",
      "options": {
        "cwd": "${workspaceFolder}/e2e-tests"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "workflex-test"
      },
      "problemMatcher": []
    },
    {
      "label": "Start App",
      "dependsOn": [
        "Backend",
        "Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Start All",
      "dependsOn": [
        "PG Up",
        "Backend",
        "Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
