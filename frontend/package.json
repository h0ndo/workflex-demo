{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --max-warnings=0",
    "lint:scss:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json,md}\"",
    "check": "npm run lint && npm run lint:scss && npm run format:check",
    "generate:api": "openapi-typescript http://localhost:8080/v3/api-docs -o src/libs/core-lib/api/generated/openapi.d.ts",
    "check:api": "npm run generate:api && git diff --exit-code -- src/libs/core-lib/api/generated/openapi.d.ts"
  },
  "private": true,
  "packageManager": "npm@9.8.1",
  "dependencies": {
    "@angular/animations": "^21.2.4",
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "openapi-typescript": "^7.10.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "stylelint": "^16.25.0",
    "stylelint-config-recess-order": "^7.4.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.0.8"
  }
}
